# Audit Configuration
AUDIT_BASE_URL=https://example.com
AUDIT_DEPTH=2
AUDIT_TIMEOUT_MS=30000

# Browser
HEADLESS=true
BROWSER_ARGS=--no-sandbox

# Report
CLIENT_NAME=Example Agency
REPORT_FORMAT=pdf

# Logging
LOG_LEVEL=info

# Optional: PDF rendering
CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser
